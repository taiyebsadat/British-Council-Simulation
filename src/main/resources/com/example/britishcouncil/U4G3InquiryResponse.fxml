<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.britishcouncil.U4G3InquiryResponseController">
    <children>
        <Label layoutX="25.0" layoutY="45.0" text="Inquiry ID" />
        <TextField fx:id="inquiryidTextField" layoutX="86.0" layoutY="41.0" />
        <Label layoutX="263.0" layoutY="45.0" text="Sender Name" />
        <TextField fx:id="senderNameTextField" layoutX="345.0" layoutY="41.0" />

        <TableView fx:id="inquiryTableView" layoutX="363.0" layoutY="134.0" prefHeight="200.0" prefWidth="200.0">
            <columns>
                <TableColumn fx:id="inquiryIdTableColumn" prefWidth="101.0" text="Inquiry ID" />
                <TableColumn fx:id="StatusTableColumn" prefWidth="98.0" text="Status" />
            </columns>
        </TableView>

        <Label layoutX="25.0" layoutY="104.0" text="Status" />
        <RadioButton fx:id="statusResolvedRadioButton" layoutX="72.0" layoutY="104.0" mnemonicParsing="false" text="Resolved">
         <toggleGroup>
            <ToggleGroup fx:id="Stat" />
         </toggleGroup></RadioButton>

        <Label layoutX="27.0" layoutY="158.0" text="Query Text" />
        <Label layoutX="27.0" layoutY="258.0" text="Response Text" />
        <TextArea fx:id="queryTextTextArea" layoutX="86.0" layoutY="134.0" prefHeight="79.0" prefWidth="200.0" />
        <TextArea fx:id="responseTextTextArea" layoutX="103.0" layoutY="223.0" prefHeight="79.0" prefWidth="200.0" />

        <Button layoutX="262.0" layoutY="333.0" mnemonicParsing="false" text="Resolved">
            <font>
                <Font size="14.0" />
            </font>
        </Button>

        <Label layoutX="272.0" layoutY="96.0" text="Resolution Time" />
        <TextField fx:id="resolutionTimeTextField" layoutX="363.0" layoutY="92.0" />
      <Button layoutX="78.0" layoutY="335.0" mnemonicParsing="false" onAction="#LoadButton" text="Load" />
      <Button layoutX="450.0" layoutY="348.0" mnemonicParsing="false" onAction="#BackButton" text="Back" />
    </children>
</AnchorPane>
