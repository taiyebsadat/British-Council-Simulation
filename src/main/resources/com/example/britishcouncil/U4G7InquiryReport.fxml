<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.britishcouncil.U4G7InquiryReportController">
   <children>
      <TextField fx:id="reportIdTF" layoutX="43.0" layoutY="42.0" promptText="Report Id" />
      <TextField fx:id="aoTF" layoutX="43.0" layoutY="76.0" promptText="Assigned Officer" />
      <TextArea fx:id="descriptionTA" layoutX="43.0" layoutY="132.0" prefHeight="241.0" prefWidth="149.0" promptText="Description" />
      <ComboBox fx:id="categoryCB" layoutX="225.0" layoutY="42.0" prefWidth="150.0" promptText="Category" />
      <ComboBox fx:id="priorityCB" layoutX="408.0" layoutY="42.0" prefWidth="150.0" promptText="Priority" />
      <Button layoutX="226.0" layoutY="76.0" mnemonicParsing="false" onAction="#addButton" prefHeight="25.0" prefWidth="335.0" text="Add" />
      <TableView fx:id="table" layoutX="225.0" layoutY="132.0" prefHeight="191.0" prefWidth="335.0">
        <columns>
          <TableColumn fx:id="reportIdCol" prefWidth="118.0" text="Report ID" />
          <TableColumn fx:id="createdDateCol" prefWidth="96.0" text="Date" />
            <TableColumn fx:id="statusCol" prefWidth="120.0" text="Status" />
        </columns>
      </TableView>
      <Button layoutX="240.0" layoutY="341.0" mnemonicParsing="false" onAction="#load" text="Load All Reports" />
      <Button layoutX="382.0" layoutY="341.0" mnemonicParsing="false" onAction="#BackButton" prefHeight="25.0" prefWidth="53.0" text="Back" />
   </children>
</AnchorPane>
