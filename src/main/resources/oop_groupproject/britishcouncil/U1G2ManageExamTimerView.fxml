<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<?import javafx.scene.layout.VBox?>
<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="oop_groupproject.britishcouncil.U1G2ManageExamTimerViewController">
        <TextField fx:id="durationTextField" promptText="Enter Duration (minutes)"/>
        <Button text="Start Timer" onAction="#startButtonOnAction"/>
        <Button text="Stop Timer" onAction="#stopButtonOnAction"/>
        <Button text="Check Time" onAction="#checkButtonOnAction"/>
        <Label fx:id="statusLabel"/>
        <Button text="Back" onAction="#backButtonOnAction"/>
</AnchorPane>
