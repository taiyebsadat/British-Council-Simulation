<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.britishcouncil.IeltsCandidate.Controller.enrollCourseController">

    <children>
        <Label layoutX="265.0" layoutY="26.0" prefWidth="144.0" text="Enroll Course" />

        <Button layoutX="277.0" layoutY="282.0" onAction="#enrollButton" text="Enroll" />
      <ComboBox editable="true" layoutX="225.0" layoutY="72.0" prefWidth="150.0" promptText="Course ID" />
      <TableView fx:id="courseDetailsTableView" layoutX="148.0" layoutY="127.0" prefHeight="114.0" prefWidth="304.0">
        <columns>
          <TableColumn fx:id="courseIDCol" prefWidth="75.0" text="Course ID" />
          <TableColumn fx:id="titleCol" prefWidth="75.0" text="Title" />
            <TableColumn fx:id="feeCol" prefWidth="75.0" text="Fee" />
            <TableColumn fx:id="schedule" prefWidth="75.0" text="Schedule" />
        </columns>
      </TableView>
    </children>

</AnchorPane>
