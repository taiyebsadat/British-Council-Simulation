<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0"  xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="oop_groupproject.britishcouncil.IeltsCandidate.Controller.CandidateDashboardController">
    <children>
        <Label layoutX="195.0" layoutY="40.0" text="IELTS Candidate Dashboard" textFill="#1a5276">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>
        <FlowPane hgap="20.0" layoutX="50.0" layoutY="100.0" prefHeight="250.0" prefWidth="500.0" vgap="20.0">
            <children>
                <Button mnemonicParsing="false" onAction="#handleEnrollCourse" prefHeight="60.0" prefWidth="150.0" text="Enroll in Course" />
                <Button mnemonicParsing="false" onAction="#handleViewCourses" prefHeight="60.0" prefWidth="150.0" text="View Course List" />
                <Button mnemonicParsing="false" onAction="#handleViewSchedule" prefHeight="60.0" prefWidth="150.0" text="Class Schedule" />
                <Button mnemonicParsing="false" onAction="#handleSubmitHomework" prefHeight="60.0" prefWidth="150.0" text="Submit Homework" />
                <Button mnemonicParsing="false" onAction="#handleStartMockTest" prefHeight="60.0" prefWidth="150.0" text="Start Mock Test" />
                <Button mnemonicParsing="false" onAction="#handleViewScores" prefHeight="60.0" prefWidth="150.0" text="View Test Scores" />
                <Button mnemonicParsing="false" onAction="#handlePayFee" prefHeight="60.0" prefWidth="150.0" text="Pay Course Fee" />
                <Button mnemonicParsing="false" onAction="#handleDownloadInvoice" prefHeight="60.0" prefWidth="150.0" text="Download Invoice" />
            </children>
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
        </FlowPane>
    </children>
</AnchorPane>