<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.britishcouncil.IeltsCandidate.Controller.downloadInvoiceController">

    <children>
        <Label layoutX="220.0" layoutY="20.0" text="Download Invoice" />

        <TextField fx:id="paymentIDTextField" layoutX="200.0" layoutY="100.0" promptText="Payment ID" />

        <Button layoutX="250.0" layoutY="160.0" onAction="#downloadButton" text="Download" />
    </children>

</AnchorPane>
