<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="326.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.britishcouncil.IeltsCandidate.Controller.studentActivitiesController">

    <children>

        <!-- Scores Section -->
        <Label layoutX="20.0" layoutY="20.0" style="-fx-font-weight: bold; -fx-font-size: 14px;" text="Scores" />
        <TableView fx:id="scoreTable" layoutX="20.0" layoutY="50.0" prefHeight="220.0" prefWidth="560.0">
            <columns>
                <TableColumn fx:id="testIdCol" text="Test ID" />
                <TableColumn fx:id="scoreCol" text="Score" />
                <TableColumn fx:id="bandCol" text="Band" />
            </columns>
        </TableView>
        <Button layoutX="240.0" layoutY="280.0" onAction="#loadScoresTable" text="Load Scores" />

    </children>

</AnchorPane>
