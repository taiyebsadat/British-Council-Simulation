<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefWidth="400" prefHeight="300" xmlns:fx="http://javafx.com/fxml" fx:controller="oop_groupproject.britishcouncil.LoginViewController">
    <VBox spacing="10" layoutX="50" layoutY="50">
        <TextField fx:id="userIdTextField" promptText="User ID" />
        <PasswordField fx:id="passwordField" promptText="Password" />
        <Button text="Login" onAction="#loginButtonOnAction" />
        <Label fx:id="messageLabel" />
    </VBox>
</AnchorPane>
