<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="oop_groupproject.britishcouncil.ExamRegistrationOfficer.Controller.updateCandidateController">
    <children>
        <Label layoutX="196.0" layoutY="35.0" text="Update Candidate Info">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>

        <Label layoutX="76.0" layoutY="100.0" text="Candidate ID:" />
        <TextField fx:id="CandidateIDTextField" layoutX="165.0" layoutY="96.0" promptText="Enter Candidate ID" />

        <Label layoutX="315.0" layoutY="100.0" text="Passport No:" />
        <TextField fx:id="passportNoTextField" editable="false" layoutX="394.0" layoutY="96.0" promptText="Read-only" style="-fx-background-color: #f4f4f4;" />

        <Label layoutX="196.0" layoutY="137.0" text="New Candidate Name / Info:" />
        <TextArea fx:id="newInfoTextArea" layoutX="196.0" layoutY="157.0" prefHeight="80.0" prefWidth="222.0" promptText="Enter updated details here..." />

        <Button layoutX="240.0" layoutY="260.0" onAction="#UpdateRecordButton" prefHeight="30.0" prefWidth="120.0" text="Update Record" />
    </children>
</AnchorPane>