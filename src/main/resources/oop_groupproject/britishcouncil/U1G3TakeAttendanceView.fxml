<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>
<?import java.lang.String?>

<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.Label?>
<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="oop_groupproject.britishcouncil.U1G3TakeAttendanceViewController">
    <VBox spacing="10" layoutX="50" layoutY="50">

        <TextField fx:id="studentIdTextField" promptText="Student ID"/>
        <TextField fx:id="seatTextField" promptText="Seat Number"/>

        <ComboBox fx:id="statusComboBox">
            <items>
                <FXCollections fx:factory="observableArrayList">
                    <String fx:value="Present"/>
                    <String fx:value="Absent"/>
                </FXCollections>
            </items>
        </ComboBox>

        <Button text="Save Attendance" onAction="#saveButtonOnAction"/>
        <Label fx:id="resultLabel"/>

    </VBox>
</AnchorPane>