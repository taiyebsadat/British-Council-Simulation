<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" prefHeight="300.0" prefWidth="400.0" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.britishcouncil.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="British Council Portal">
        <font>
            <Font name="System Bold" size="20.0" />
        </font>
    </Label>

    <Button onAction="#onOfficerDashClick" prefWidth="250.0" prefHeight="40.0" text="Exam Registration Officer Dashboard" />
    <Button onAction="#onCandidateDashClick" prefWidth="250.0" prefHeight="40.0" text="IELTS Candidate Dashboard" />
</VBox>